{
    "manifest_version": 3,
    "name": "DocHarvest",
    "version": "2.0",
    "description": "Bulk download documents from Google Classroom in a few clicks.",

    "permissions":
    [
        "activeTab",
        "scripting",
        "downloads"
    ],

    "icons":
    {
        "16": "assets/logo.png",
        "48": "assets/logo.png",
        "128": "assets/logo.png"
    },

    "action":
    {
        "default_icon": "assets/logo.png",
        "default_popup": "pop.html",
        "default_title": "DocHarvest for Google Classroom"
    }
}
